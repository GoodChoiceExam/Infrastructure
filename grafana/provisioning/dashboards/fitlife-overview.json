          { "matcher": { "id": "byName", "options": "Trainer" },      "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        { "expr": "sum(count_over_time({container=\"fitlife_identity\"}    |= \"ERROR\" [2m]))", "legendFormat": "Identity",     "refId": "A" },
