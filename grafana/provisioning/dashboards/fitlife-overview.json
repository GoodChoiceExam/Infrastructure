  "uid": "fitlife-overview",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "tags": ["fitlife"],
  "graphTooltip": 1,
  "panels": [

    {
      "id": 1, "type": "stat", "title": "Identity",
      "description": "Active if logs received in the last 5 minutes",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto", "reduceOptions": { "calcs": ["sum"], "values": false } },
      "fieldConfig": {
        "defaults": {
          "noValue": "Offline",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "mappings": [
            { "type": "special", "options": { "match": "null+nan", "result": { "text": "Offline", "color": "red", "index": 0 } } },
            { "type": "value", "options": { "0": { "text": "Offline", "color": "red", "index": 1 } } },
            { "type": "range", "options": { "from": 1, "to": 1e15, "result": { "text": "Online", "color": "green", "index": 2 } } }
          ]
        }
      },
      "targets": [{ "expr": "count_over_time({container=\"fitlife_identity\"}[5m])", "refId": "A" }]
    },

